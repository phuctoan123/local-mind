# Mistral / LeChat mode
LLM_PROVIDER=mistral
EMBEDDING_PROVIDER=mistral
MISTRAL_API_KEY=REPLACE_WITH_YOUR_MISTRAL_API_KEY
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest
MISTRAL_EMBED_MODEL=mistral-embed
MISTRAL_TIMEOUT=120

# Google AI Studio mode is disabled. Uncomment these lines and switch providers
# to google if you want to use Gemini instead.
# LLM_PROVIDER=google
# EMBEDDING_PROVIDER=google
# GOOGLE_API_KEY=REPLACE_WITH_YOUR_GOOGLE_API_KEY
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GOOGLE_MODEL=gemini-2.5-flash
# GOOGLE_EMBED_MODEL=gemini-embedding-001
# GOOGLE_TIMEOUT=120

# Ollama mode is disabled. Uncomment these lines and switch providers back to
# ollama if you want to run fully local again.
# LLM_PROVIDER=ollama
# EMBEDDING_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=phi3:mini
# OLLAMA_EMBED_MODEL=nomic-embed-text:latest
# OLLAMA_TIMEOUT=600

# LLM Parameters
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.9
LLM_NUM_CTX=4096
LLM_NUM_PREDICT=1024

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MIN_CHUNK_LENGTH=50

# Retrieval
RETRIEVAL_MODE=hybrid
TOP_K=3
MIN_SIMILARITY_SCORE=0.15
MAX_CONTEXT_TOKENS=2400
VECTOR_TOP_K=20
BM25_TOP_K=20
RRF_K=60
ENABLE_QUERY_REWRITING=true
ENABLE_RERANKING=true
RERANK_CANDIDATE_K=12
ENABLE_CITATION_VALIDATION=true

# Storage
DATA_DIR=./data
RAW_FILES_DIR=./data/raw
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_PATH=./data/sqlite/app.db
VECTOR_STORE=chroma
CHROMA_COLLECTION=documents_mistral

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
API_KEY=

# Upload
MAX_UPLOAD_SIZE_MB=50
MAX_DOCX_ZIP_ENTRIES=500
MAX_DOCX_UNCOMPRESSED_MB=100
MAX_DOCX_COMPRESSION_RATIO=100
ALLOWED_EXTENSIONS=pdf,txt,docx

# Session
SESSION_TTL_MINUTES=30
MAX_HISTORY_TURNS=10

# Optional Features
ENABLE_OCR=false
ENABLE_STREAMING=true
LOG_LEVEL=INFO
